<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    app:fitsSystemWindowsInsets="bottom|start|end"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceContainerLow"
            app:cardCornerRadius="16dp"
            app:contentPadding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/diagnostic_section_service"
                    android:textAppearance="?textAppearanceTitleMedium"
                    android:textColor="?colorPrimary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/check_shizuku_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

                <TextView
                    android:id="@+id/check_shizuku_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceContainerLow"
            app:cardCornerRadius="16dp"
            app:contentPadding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/diagnostic_section_adb"
                    android:textAppearance="?textAppearanceTitleMedium"
                    android:textColor="?colorPrimary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/check_usb_debugging"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

                <TextView
                    android:id="@+id/check_wireless_debugging"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

                <TextView
                    android:id="@+id/check_adb_tcp_port"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?colorSurfaceContainerLow"
            app:cardCornerRadius="16dp"
            app:contentPadding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/diagnostic_section_system"
                    android:textAppearance="?textAppearanceTitleMedium"
                    android:textColor="?colorPrimary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/check_android_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

                <TextView
                    android:id="@+id/check_root_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

                <TextView
                    android:id="@+id/check_battery_optimization"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

                <TextView
                    android:id="@+id/check_developer_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
